{
  "extends": "@acdh-oeaw/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./*"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "next-env.d.ts",
    "app.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.config.mjs",
    "scripts/*.loader.cjs",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "out", "public"]
}
