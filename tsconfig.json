{
  "extends": "@acdh-oeaw/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "app.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.config.mjs",
    "scripts/*.loader.cjs"
  ],
  "exclude": ["node_modules", ".next", "out", "public"]
}
